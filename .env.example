# Database Configuration
# SQLite (default)
DATABASE_URL=sqlite:///./todos.db

# PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost/todo_db

# MySQL
# DATABASE_URL=mysql+pymysql://username:password@localhost/todo_db

# JWT Configuration
# Generate a secure secret key with: openssl rand -hex 32
JWT_SECRET_KEY=your-secure-secret-key-here-change-in-production

# Application Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (if needed)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
# LOG_LEVEL=INFO

# Development/Production
# ENVIRONMENT=development